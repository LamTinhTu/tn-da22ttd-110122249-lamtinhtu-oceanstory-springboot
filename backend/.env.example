# =========================
# Backend environment config
# Copy this file to `.env` (same folder) and fill values.
# =========================

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/ocean_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
# NOTE: HMAC key should be 32+ characters.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION_MS=86400000

# Google OAuth (optional - required only for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upload directory (optional)
UPLOAD_DIR=uploads

# Optional: bootstrap default users on startup (DEV ONLY)
BOOTSTRAP_ENABLED=false
BOOTSTRAP_RESET_PASSWORD=false

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@ocean.local
BOOTSTRAP_ADMIN_PASSWORD=

BOOTSTRAP_MODERATOR_USERNAME=moderator
BOOTSTRAP_MODERATOR_EMAIL=moderator@ocean.local
BOOTSTRAP_MODERATOR_PASSWORD=
