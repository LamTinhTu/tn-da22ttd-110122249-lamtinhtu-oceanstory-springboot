{
  "info": {
    "_postman_id": "6d4b0a5e-2c02-4fcd-89a7-6dff4f457b41",
    "name": "Ocean Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection test API xac thuc cho nen tang truyen online"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_demo\",\n  \"email\": \"user_demo@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "description": "Dang ky tai khoan moi voi role mac dinh USER"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code la 201 hoac 400', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 201) {",
              "  var jsonData = pm.response.json();",
              "  pm.test('Message dang ky thanh cong', function () {",
              "    pm.expect(jsonData.message).to.eql('Dang ky thanh cong');",
              "  });",
              "}",
              "",
              "if (pm.response.code === 400) {",
              "  pm.test('Co message loi hop le', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('message');",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_demo\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Dang nhap va lay JWT token"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code la 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Response co token va role', function () {",
              "  pm.expect(jsonData).to.have.property('token');",
              "  pm.expect(jsonData).to.have.property('role');",
              "});",
              "",
              "pm.environment.set('token', jsonData.token);",
              "pm.collectionVariables.set('token', jsonData.token);"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
